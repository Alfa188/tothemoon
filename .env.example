# Proxy Configuration
# PROXY_PROVIDER: iproyal | geonode
#
# IPRoyal: https://iproyal.com
#   HOST=geo.iproyal.com PORT=12321
#   Options go in password: pass_country-US_session-X_lifetime-10m
#
# Geonode (recommended): https://app.geonode.com/proxies
#   HOST=proxy.geonode.io PORT=9010 (premium residential)
#   Options go in username: user-country-US
#   NOTE: sticky sessions NOT supported on port 9010
PROXY_ENABLED=true
PROXY_PROVIDER=geonode
PROXY_HOST=proxy.geonode.io
PROXY_PORT=9010
PROXY_USERNAME=your_geonode_username
PROXY_PASSWORD=your_geonode_password
PROXY_TYPE=residential
PROXY_COUNTRY=
PROXY_STICKY=false
PROXY_STICKY_LIFETIME=10m

# Bot Settings
MAX_CONCURRENT_SESSIONS=1
LOG_LEVEL=info
