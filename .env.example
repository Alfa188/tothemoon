# IPRoyal Residential Proxy
# https://iproyal.com — Sticky sessions, country targeting
PROXY_ENABLED=true
PROXY_HOST=geo.iproyal.com
PROXY_PORT=12321
PROXY_USERNAME=your_iproyal_username
PROXY_PASSWORD=your_iproyal_password
PROXY_COUNTRY=
PROXY_STICKY=true
PROXY_STICKY_LIFETIME=2h

# Bot Settings
MAX_CONCURRENT_SESSIONS=30
LOG_LEVEL=info
