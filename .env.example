# Geonode Residential Proxy — port 9010 (premium, no sticky)
# https://app.geonode.com/proxies
PROXY_ENABLED=true
PROXY_PROVIDER=geonode
PROXY_HOST=proxy.geonode.io
PROXY_PORT=9010
PROXY_USERNAME=geonode_YOUR_USERNAME
PROXY_PASSWORD=your-geonode-password
PROXY_COUNTRY=
PROXY_STICKY=false

# IPRoyal alternative (sticky sessions 2h)
# PROXY_PROVIDER=iproyal
# PROXY_HOST=geo.iproyal.com
# PROXY_PORT=12321
# PROXY_USERNAME=your_iproyal_username
# PROXY_PASSWORD=your_iproyal_password
# PROXY_STICKY=true
# PROXY_STICKY_LIFETIME=2h

# Bot Settings
MAX_CONCURRENT_SESSIONS=30
LOG_LEVEL=info
