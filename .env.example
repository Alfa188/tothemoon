# Proxy Configuration
# PROXY_PROVIDER: iproyal | geonode
#
# IPRoyal (recommended): https://iproyal.com
#   HOST=geo.iproyal.com PORT=12321
#   Options go in password: pass_country-US_session-X_lifetime-10m
#
# Geonode: https://app.geonode.com/proxies
#   HOST=proxy.geonode.io PORT=9000
#   Options go in username: user-type-residential-country-US
PROXY_ENABLED=true
PROXY_PROVIDER=iproyal
PROXY_HOST=geo.iproyal.com
PROXY_PORT=12321
PROXY_USERNAME=your_iproyal_username
PROXY_PASSWORD=your_iproyal_password
PROXY_TYPE=residential
PROXY_COUNTRY=
PROXY_STICKY=true
PROXY_STICKY_LIFETIME=10m

# Bot Settings
MAX_CONCURRENT_SESSIONS=30
LOG_LEVEL=info
