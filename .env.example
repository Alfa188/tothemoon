# Proxy Configuration (Geonode Residential)
# Docs: https://app.geonode.com/proxies
PROXY_ENABLED=true
PROXY_HOST=proxy.geonode.io
PROXY_PORT=9000
PROXY_USERNAME=geonode_XXXXXXXX
PROXY_PASSWORD=your-uuid-password-here
PROXY_TYPE=residential
PROXY_COUNTRY=
PROXY_STICKY=true
PROXY_STICKY_LIFETIME=10m

# Bot Settings
MAX_CONCURRENT_SESSIONS=30
LOG_LEVEL=info
